# Twin Admin - Environment Template

# AI (copy from devops/.env)
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# Image gen for enhanced view (copy from devops/.env)
FAL_AI_KEY=your-fal-key
REPLICATE_API_TOKEN=r8_...

# HeyGen avatar (copy from broadcastx/.env)
HEYGEN_API_KEY=sk_V2_...
HEYGEN_AVATAR_ID=Josh
HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad0158f3d

# LiveKit WebRTC (livekit.starshop.cc on K8s)
LIVEKIT_URL=wss://livekit.starshop.cc
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Telegram bot (copy from devops/.env)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
# Optional: base URL for telegram-bot.js (default localhost:3000)
# TWIN_ADMIN_URL=http://localhost:3000

# Database
POSTGRES_PASSWORD=change-me-in-production

# Auth
JWT_SECRET=generate-64-char-secret
NEXTAUTH_SECRET=generate-32-char-secret
NEXTAUTH_URL=http://localhost:3101

# License Key Generation
LICENSE_SECRET=license-hmac-secret-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Product API URLs (for usage sync, optional)
SURGITWIN_API_URL=
GLOWMORPH_API_URL=
